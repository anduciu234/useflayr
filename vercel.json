{
  "routes": [
    { "src": "/auth/callback", "dest": "/auth/callback.html" },
    { "src": "/api/deauth",    "dest": "/api/deauth.html" },
    { "src": "/api/delete",    "dest": "/api/delete.html" },
    { "src": "/privacy",       "dest": "/privacy.html" },
    { "src": "/terms",         "dest": "/terms.html" },
    { "src": "/preview",       "dest": "/preview.html" },
    { "src": "/x-card",        "dest": "/x-card.html" },
    { "src": "/robots.txt",    "dest": "/robots.txt" },
    { "src": "/sitemap.xml",   "dest": "/sitemap.xml" },
    { "src": "/(.*\\.(?:html|txt|xml|png|jpg|jpeg|svg|gif|ico|webp|mp4|webm|css|js|woff2?|ttf|eot)$)", "dest": "/$1" },
    { "src": "/(.*)",          "dest": "/index.html" }
  ]
}
